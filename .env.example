# Mistral API Configuration (Optional - set if using Mistral)
MISTRAL_API_KEY=your_mistral_api_key_here

# Ollama Configuration (Optional - set if using Ollama)
# Default: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3-vl:4b

# Tandoor Configuration
TANDOOR_URL=http://192.168.1.100:8080
TANDOOR_API_TOKEN=your_tandoor_api_token_here

# Port Configuration
BACKEND_PORT=3001
FRONTEND_PORT=5173

# Backend Configuration (optional overrides)
# NODE_ENV=production
# MAX_FILE_SIZE=10485760
# UPLOAD_DIR=./uploads
